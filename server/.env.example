# =============================================================================
# CDMS server — copy to .env and/or .env.local (see docs/SUPABASE.md)
# Loaded in order: .env then .env.local (local overrides; gitignored).
# =============================================================================

# --- PostgreSQL (choose ONE setup) -------------------------------------------

# Option A — Local Postgres (same URL twice)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cdms"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cdms"

# Option B — Supabase (from Dashboard → Project Settings → Database → URI)
# Use pooler URL + ?pgbouncer=true for DATABASE_URL, and direct :5432 for DIRECT_URL.
# Dashboard: https://supabase.com/dashboard
# Guide: ../docs/SUPABASE.md
#
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cdms"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cdms"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Default port for Express (client REACT_APP_API_URL should match, e.g. http://localhost:5000/api)
PORT=5000

NODE_ENV=development

# Production CORS: comma-separated allowed origins (e.g. https://app.example.com)
FRONTEND_URL=http://localhost:3000

# Elevated roles (ADMIN, ACCOUNTANT, …) are not creatable via public /api/auth/register.
# Promote users with Prisma Studio, a one-off script, or a future admin invite flow.

# Production: serve CRA build from Express (same origin). Default path is ../../client/build from dist/.
# SERVE_STATIC=true
# CLIENT_DIST_PATH=/absolute/path/to/client/build
