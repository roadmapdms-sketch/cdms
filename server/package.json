{
  "name": "cdms-server",
  "version": "1.0.0",
  "description": "Church Data Management System Backend",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "dotenv -e .env -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "db:resolve-applied": "dotenv -e .env -e .env.local -- prisma migrate resolve --applied",
    "db:generate": "dotenv -e .env -e .env.local -- prisma generate",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:sync-users-to-members": "ts-node src/scripts/syncUsersToMembers.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/node": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^17.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
