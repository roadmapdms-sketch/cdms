# Copy to .env.local and adjust. Must include /api if your server mounts routes there.
# Local dev default server port is often 5001 (see server/.env.example). Docker same-origin: :5000/api.
REACT_APP_API_URL=http://localhost:5001/api

# Optional: login/register only. Use on Vercel when REACT_APP_API_URL is your Express host but that
# host is down — point auth at the main app’s serverless API, e.g. https://YOUR-APP.vercel.app/api
# REACT_APP_AUTH_API_URL=https://cdms-phi.vercel.app/api
